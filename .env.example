# ─────────────────────────────────────────────
# AI Demystified Starter Kit — Environment File
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# LLM Provider Selection
# Options: "openai" | "groq"
LLM_PROVIDER=openai

# OpenAI Configuration
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Groq Configuration (alternative LLM provider)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Pinecone Configuration (for future RAG integration)
PINECONE_API_KEY=
PINECONE_ENV=dev
PINECONE_INDEX=ai-demystified-1536

# Tavily Configuration
TAVILY_API_KEY=